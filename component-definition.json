                }
              ]
            }
          }
        },
        {
          "title": "Fragment",
          "id": "fragment",
          "model": "fragment",
          "plugins": {
            "da": {
              "unsafeHTML": "<div class=\"fragment\"><div><div><p><a href=\"\">Fragment URL</a></p></div></div></div>",
              "fields": [
                {
                  "name": "url",
                  "selector": "div>div>p>a[href]"
                },
                {
                  "name": "urlText",
                  "selector": "div>div>p>a"
                }
              ]
            }
          }
        },
        {
          "title": "Header",
          "id": "header",
          "model": "header",
          "plugins": {
            "da": {
              "name": "header",
              "rows": 1,
              "columns": 1,
              "fields": [
                {
                  "name": "content",
                  "selector": "div:nth-child(1)"
                }
              ]
            }
          }
        },
        {
          "title": "Hero Banner",
          "id": "hero-banner",
          "model": "hero-banner",
          "plugins": {
            "da": {
              "name": "hero-banner",
              "rows": 2,
              "columns": 1,
              "fields": [
                {
                  "name": "image",
                  "selector": "div:nth-child(1) > div picture > img[src], div:nth-child(1) picture > img[src], div:nth-child(1) > div picture img, div:nth-child(1) picture img"
                },
                {
                  "name": "imageAlt",
                  "selector": "div:nth-child(1) > div picture > img[alt], div:nth-child(1) picture > img[alt], div:nth-child(1) > div picture img, div:nth-child(1) picture img"
                },
                {
                  "name": "content",
                  "selector": "div:nth-child(2) > div"
                }
              ]
            }
          }
        },
        {
          "title": "Hero",
          "id": "hero",
          "model": "hero",
          "plugins": {
            "da": {
              "name": "hero",
              "rows": 2,
              "columns": 1,
              "fields": [
                {
                  "name": "image",
                  "selector": "div:nth-child(1) > div picture > img[src], div:nth-child(1) picture > img[src], div:nth-child(1) > div picture img, div:nth-child(1) picture img"
                },
                {
                  "name": "imageAlt",
                  "selector": "div:nth-child(1) > div picture > img[alt], div:nth-child(1) picture > img[alt], div:nth-child(1) > div picture img, div:nth-child(1) picture img"
                },
                {
                  "name": "text",
                  "selector": "div:nth-child(2) > div"
                }
              ]
            }
          }
        },
